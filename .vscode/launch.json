{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Singer Backend",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/singer",
      "cwd": "${workspaceFolder}",
      "args": [
        "--config",
        "${workspaceFolder}/.vscode/congfig-debug.yaml",
        "--addr",
        ":8080"
      ],
      "env": {
        "GIN_MODE": "debug",
        "GOCACHE": "${workspaceFolder}/.cache/go-build"
      }
    },
    {
      "name": "Debug Skill Proxy",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/skill-proxy",
      "cwd": "${workspaceFolder}",
      "env": {
        "GOCACHE": "${workspaceFolder}/.cache/go-build"
      }
    }
  ]
}
